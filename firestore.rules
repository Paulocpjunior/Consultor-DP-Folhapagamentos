rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────
    function isSignedIn()  { return request.auth != null; }
    function userDoc()     { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isApproved()  { return isSignedIn() && userDoc().role in ['admin','colaborador']; }
    function isAdmin()     { return isSignedIn() && userDoc().role == 'admin'; }

    // ─── users ────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Self-create: usuário cria seu próprio doc com role 'pendente' OU 'admin' (1º usuário)
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role in ['pendente','admin']
                    && request.resource.data.uid == request.auth.uid;
      // Admin promove/rebaixa
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Catálogo de eventos IOB SAGE (compartilhado) ────────────────
    match /folha_catalogo/{docId} {
      allow read:  if isApproved();
      allow write: if isAdmin();
    }

    // ─── Seleção de eventos por cliente (compartilhado entre admins) ─
    match /folha_selecoes_eventos/{cliente} {
      allow read, write: if isApproved();
    }

    // ─── Mapeamento por cliente ──────────────────────────────────────
    match /folha_mapeamentos/{cliente} {
      allow read, write: if isApproved();
    }

    // ─── Histórico de exportações (por cliente) ──────────────────────
    match /folha_historico/{cliente}/exportacoes/{logId} {
      allow read:   if isApproved();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }

    // ─── Cache de preferências por usuário ───────────────────────────
    match /users/{uid}/cache/{key} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Bloqueio padrão
    match /{document=**} { allow read, write: if false; }
  }
}
