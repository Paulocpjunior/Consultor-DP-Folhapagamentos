rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn()  { return request.auth != null; }
    function userDoc()     { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isApproved()  { return isSignedIn() && userDoc().role in ['admin','colaborador']; }
    function isAdmin()     { return isSignedIn() && userDoc().role == 'admin'; }

    match /users/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list:   if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role in ['pendente','admin']
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Empresas: cada usuário cadastra/lê/edita as suas; admin vê todas
    match /empresas/{empresaId} {
      allow read:   if isApproved() && (
                       resource == null
                       || resource.data.criadoPor == request.auth.uid
                       || isAdmin()
                    );
      allow list:   if isApproved();
      allow create: if isApproved()
                    && request.resource.data.criadoPor == request.auth.uid
                    && request.resource.data.cnpj is string
                    && request.resource.data.razaoSocial is string
                    && request.resource.data.nomeFantasia is string
                    && request.resource.data.codigoSage is string;
      allow update: if isApproved() && (
                       resource.data.criadoPor == request.auth.uid
                       || isAdmin()
                    );
      allow delete: if isApproved() && (
                       resource.data.criadoPor == request.auth.uid
                       || isAdmin()
                    );
    }

    match /folha_catalogo/{docId} {
      allow read:  if isApproved();
      allow write: if isAdmin();
    }

    match /folha_selecoes_eventos/{cliente} {
      allow read, write: if isApproved();
    }

    match /folha_mapeamentos/{cliente} {
      allow read, write: if isApproved();
    }


    match /folha_historico/{cliente}/exportacoes/{logId} {
      allow read:   if isApproved();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }

    match /users/{uid}/cache/{key} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /folha_eventos_audit/{auditId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if false;
    }

    match /folha_perfis_colunas/{cnpj} {
      allow read: if isApproved();
      allow write: if isApproved();
    }
    // ===== Ponto Eletronico =====

    // Catalogo de modelos de ponto (ACJEF, DIMEP, Henry, Ahgora, etc).
    // Leitura: qualquer usuario aprovado. Escrita: so admin (catalogo compartilhado).
    match /ponto_modelos/{modeloId} {
      allow read:   if isApproved();
      allow list:   if isApproved();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Layouts de ponto por empresa (CNPJ + cadastro SAGE).
    // Mesma logica de empresas: usuario aprovado le e escreve.
    match /ponto_layouts/{layoutId} {
      allow read:   if isApproved();
      allow list:   if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isApproved();
    }



    match /{document=**} { allow read, write: if false; }
  }
}
